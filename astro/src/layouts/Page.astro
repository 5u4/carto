---
import { loadIr, tree, staleIds } from "../lib/carto";
import type { Node } from "../lib/carto";

interface Props {
  node: Node;
  locale: string;
}

const { node, locale } = Astro.props;
const ir = loadIr();
const items = tree(ir);
const locales = ir.vault.locales;
const isStale = staleIds.has(node.id);
const hasChildren = node.children.length > 0;

const href = (id: string): string => `${import.meta.env.BASE_URL}${locale}/${id}/`;
const switchHref = (loc: string): string => `${import.meta.env.BASE_URL}${loc}/${node.id}/`;
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{node.name} — {ir.vault.name}</title>
    <style>
      :root { color-scheme: light; }
      * { box-sizing: border-box; }
      body { margin: 0; font: 16px/1.6 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; }
      .shell { display: flex; min-height: 100vh; }
      nav { width: 280px; flex: 0 0 280px; border-right: 1px solid #e5e5e5; padding: 1.5rem 1rem; overflow-y: auto; background: #fafafa; }
      nav .project { font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #666; margin-bottom: 1rem; }
      nav ul { list-style: none; margin: 0; padding: 0; }
      nav a { display: block; padding: 0.2rem 0.5rem; border-radius: 4px; color: #333; text-decoration: none; font-size: 0.9rem; }
      nav a:hover { background: #eee; }
      nav a.active { background: #1a1a1a; color: #fff; }
      main { flex: 1; min-width: 0; padding: 2rem 3rem; max-width: 860px; }
      main :global(pre) { padding: 1rem; border-radius: 6px; overflow-x: auto; font-size: 0.85rem; }
      main :global(h1) { margin-top: 0; }
      .hint { padding: 0.6rem 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.9rem; }
      .hint.stale { background: #fff4e5; border: 1px solid #ffcc80; color: #8a5300; }
      .hint.leaf { background: #f0f0f0; border: 1px solid #ddd; color: #555; }
      .locales { margin-bottom: 1rem; font-size: 0.85rem; }
      .locales a { color: #0366d6; text-decoration: none; margin-right: 0.5rem; }
      .locales a.current { color: #666; font-weight: 700; }
      @media (max-width: 720px) {
        .shell { flex-direction: column; }
        nav { width: 100%; flex: none; border-right: none; border-bottom: 1px solid #e5e5e5; }
        main { padding: 1.5rem 1.25rem; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <nav>
        <div class="project">{ir.vault.name}</div>
        {locales.length > 1 && (
          <div class="locales">
            {locales.map((loc) => (
              <a href={switchHref(loc)} class={loc === locale ? "current" : ""}>{loc}</a>
            ))}
          </div>
        )}
        <ul>
          {items.map(({ node: item, depth }) => (
            <li>
              <a
                href={href(item.id)}
                class={item.id === node.id ? "active" : ""}
                style={`padding-left: ${0.5 + depth * 0.9}rem`}
              >{item.name}</a>
            </li>
          ))}
        </ul>
      </nav>
      <main>
        {isStale && (
          <div class="hint stale">Source has changed since this was written — may be out of date.</div>
        )}
        <slot />
        {!hasChildren && (
          <div class="hint leaf">No sub-components generated yet — ask your agent to dig into this component.</div>
        )}
      </main>
    </div>
  </body>
</html>
