{
  "name": "carto",
  "version": "1.0.0",
  "description": "Agent-driven tool that turns a codebase into a human-readable, incrementally-maintainable static site: component responsibilities, data flow, and on-demand drill-down.",
  "bin": {
    "carto": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "keywords": [
    "codebase",
    "documentation",
    "static-site",
    "astro",
    "llm"
  ],
  "author": "sen",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "astro": "^7.0.6",
    "citty": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
